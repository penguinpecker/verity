# Verity attestor configuration.
# On Railway, set these as service Variables (do NOT commit a real key).

# The attestor's signing key. Every proof is signed with this; its address is the
# attestor identity that verifiers trust. Generate one with:
#   node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
PRIVATE_KEY=0x...

# Port to listen on. Railway sets this automatically; locally default is 8001.
PORT=8001

# debug | info | warn | error
LOG_LEVEL=info

# Number of concurrent ZK proof verifications.
ZK_CONCURRENCY=4
